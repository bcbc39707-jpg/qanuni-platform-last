# Qanuni Platform - Environment Configuration
# Copy this file to .env and fill in the values

# Application
ENVIRONMENT=development
SECRET_KEY=change-this-to-a-random-secret-key
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://qanuni:qanuni_secret@localhost:5432/qanuni_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Qdrant Vector DB
QDRANT_URL=http://localhost:6333

# AI Provider (ollama or openai)
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=aya:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# OpenAI (optional - only needed if AI_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview

# OCR Services
PADDLEOCR_URL=http://ocr:8001
GOOGLE_VISION_API_KEY=

# Email (optional)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@qanuni.ai
FRONTEND_URL=http://localhost:3000
