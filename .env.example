# Qanuni Platform — Environment Variables

# App
ENVIRONMENT=production
SECRET_KEY=yassinalzendany

# Database
POSTGRES_PASSWORD=qanuni_secret
DATABASE_URL=postgresql+asyncpg://qanuni:${POSTGRES_PASSWORD}@postgres:5432/qanuni_db

# Cache & Vector DB
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@qanuni.ai

# OCR
GOOGLE_VISION_API_KEY=your-google-vision-api-key
PADDLEOCR_URL=http://ocr:8001
